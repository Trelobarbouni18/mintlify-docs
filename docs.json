{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "name": "Prefetch API",
  "colors": {
    "primary": "#F7B00A",
    "light": "#ffc52e",
    "dark": "#F7B00A"
  },
  "favicon": "/favicon.svg",
  "font": {
    "headings": { "family": "Space Grotesk" },
    "body": { "family": "Inter" }
  },
  "codeFont": { "family": "Source Code Pro" },
  "css": "/custom.css",
  "navigation": {
    "tabs": [
      {
        "tab": "Home",
        "icon": "house",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Core concepts",
            "pages": [
              "concepts/authentication",
              "concepts/credits",
              "concepts/rate-limits",
              "concepts/errors"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "rectangle-terminal",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/endpoint/brand",
              "api-reference/endpoint/classify",
              "api-reference/endpoint/company",
              "api-reference/endpoint/screenshot",
              "api-reference/endpoint/enrich"
            ]
          }
        ]
      }
    ],
    "global": {
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://prefetch.io/dashboard"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://dashboard.prefetch.io"
    }
  },
  "contextual": {
    "options": [
      "claude",
      "copy",
      "view",
      "chatgpt",
      "perplexity",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
    }
  }
}
