{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Prefetch API",
  "colors": {
    "primary": "#F7B00A",
    "light": "#ffc52e",
    "dark": "#F7B00A",
    "background": {
      "dark": "#1a0618"
    }
  },
  "favicon": "/favicon.svg",
  "font": {
    "headings": { "family": "Space Grotesk" },
    "body": { "family": "Inter" }
  },
  "codeFont": { "family": "Source Code Pro" },
  "css": "/custom.css",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Core concepts",
            "pages": [
              "concepts/authentication",
              "concepts/credits",
              "concepts/rate-limits",
              "concepts/errors"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/endpoint/brand",
              "api-reference/endpoint/classify",
              "api-reference/endpoint/company",
              "api-reference/endpoint/screenshot",
              "api-reference/endpoint/enrich",
              "api-reference/endpoint/health",
              "api-reference/endpoint/ready"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "API Reference",
          "href": "/api-reference/introduction",
          "icon": "rectangle-terminal"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@prefetch.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://dashboard.prefetch.io"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/prefetchapi",
      "github": "https://github.com/prefetchapi"
    }
  }
}
